# ==============================================================================
# PalliCare Environment Configuration
# AIIMS Bhopal | Palliative Care & Pain Management Platform
# ==============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file to .env in the project root:  cp env.example .env
#   2. Replace all placeholder values with real credentials
#   3. NEVER commit the .env file to version control
#   4. For production, use AWS Secrets Manager or equivalent
#
# ENVIRONMENTS: local | test | staging | production
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=local
APP_NAME=PalliCare
APP_VERSION=1.0.0
APP_PORT=3000
APP_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000/api/v1
API_PREFIX=/api/v1

# WebSocket server (Socket.IO)
WS_PORT=3001
WS_CORS_ORIGIN=http://localhost:5173

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Timezone (application-level display; all DB storage is UTC)
APP_TIMEZONE=Asia/Kolkata

# ------------------------------------------------------------------------------
# PostgreSQL (Primary Database)
# ------------------------------------------------------------------------------
# Local: Docker Compose service "postgres"
# Production: AWS RDS PostgreSQL 16 Multi-AZ
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pallicare
DB_USERNAME=pallicare_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_SSL=false
# Connection pool (NestJS TypeORM / Prisma)
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=10000
# Read replica (production only)
DB_READ_HOST=
DB_READ_PORT=5432

# ------------------------------------------------------------------------------
# TimescaleDB
# ------------------------------------------------------------------------------
# TimescaleDB runs as a PostgreSQL extension on the same instance.
# No separate connection needed. These control hypertable behavior.
TIMESCALE_CHUNK_INTERVAL=7 days
TIMESCALE_COMPRESSION_AFTER=30 days
TIMESCALE_RETENTION_POLICY=730 days

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
# Local: Docker Compose service "redis"
# Production: AWS ElastiCache Redis 7 cluster
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
# Key prefix to avoid collisions in shared Redis
REDIS_KEY_PREFIX=pallicare:
# BullMQ queues (notifications, sync, analytics)
REDIS_BULL_DB=1

# ------------------------------------------------------------------------------
# Authentication (JWT + OTP)
# ------------------------------------------------------------------------------
# RS256 key paths (generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ISSUER=pallicare.aiims.edu
JWT_AUDIENCE=pallicare-api
# Token lifetimes
JWT_ACCESS_TOKEN_EXPIRY=1h
JWT_REFRESH_TOKEN_EXPIRY=30d
# Key rotation identifier
JWT_KEY_ID=key-rotation-id-2026-02

# OTP settings
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
# Rate limit: max OTP requests per phone per window
OTP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# Clinician session
CLINICIAN_SESSION_TIMEOUT_MINUTES=30
CLINICIAN_MAX_CONCURRENT_SESSIONS=3

# ------------------------------------------------------------------------------
# ABHA / ABDM Integration
# ------------------------------------------------------------------------------
# Ayushman Bharat Digital Mission (ABDM) Gateway
ABDM_GATEWAY_URL=https://dev.abdm.gov.in/gateway
ABDM_CLIENT_ID=CHANGE_ME_abdm_client_id
ABDM_CLIENT_SECRET=CHANGE_ME_abdm_client_secret
# PalliCare registered as Health Information Provider (HIP)
ABDM_HIP_ID=pallicare-aiims-bhopal
ABDM_HIP_NAME=PalliCare AIIMS Bhopal
# Callback URLs (ABDM calls these)
ABDM_CALLBACK_URL=https://api.pallicare.aiims.edu/abdm/callback
# ABHA authentication
ABHA_AUTH_URL=https://dev.abdm.gov.in/auth
ABHA_PROFILE_URL=https://dev.abdm.gov.in/account/profile
# Consent Manager
ABDM_CONSENT_MANAGER_URL=https://dev.abdm.gov.in/consent-manager
# Health Information Exchange
ABDM_HIE_URL=https://dev.abdm.gov.in/hie
# FHIR profile base for NRCES India
ABDM_FHIR_PROFILE_BASE=https://nrces.in/ndhm/fhir/r4/StructureDefinition

# ------------------------------------------------------------------------------
# FHIR Gateway
# ------------------------------------------------------------------------------
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_VERSION=R4
FHIR_CONTENT_TYPE=application/fhir+json
# HAPI FHIR server (if using HAPI; otherwise custom NestJS FHIR module)
HAPI_FHIR_ENABLED=false
HAPI_FHIR_URL=http://localhost:8080/fhir

# ------------------------------------------------------------------------------
# SMS Gateway (MSG91 - Indian DLT-compliant provider)
# ------------------------------------------------------------------------------
MSG91_AUTH_KEY=CHANGE_ME_msg91_auth_key
MSG91_SENDER_ID=PALCAR
MSG91_ROUTE=4
MSG91_TEMPLATE_OTP_ID=CHANGE_ME_template_id
MSG91_TEMPLATE_ALERT_ID=CHANGE_ME_template_id
MSG91_TEMPLATE_REMINDER_ID=CHANGE_ME_template_id
# DLT Entity ID (TRAI registration)
MSG91_DLT_ENTITY_ID=CHANGE_ME_dlt_entity_id
# Rate limit: SMS per phone per day
SMS_DAILY_LIMIT_PER_PHONE=10

# ------------------------------------------------------------------------------
# Email (AWS SES)
# ------------------------------------------------------------------------------
SES_REGION=ap-south-1
SES_ACCESS_KEY_ID=CHANGE_ME_ses_access_key
SES_SECRET_ACCESS_KEY=CHANGE_ME_ses_secret_key
SES_FROM_EMAIL=noreply@pallicare.aiims.edu
SES_FROM_NAME=PalliCare AIIMS Bhopal
SES_REPLY_TO=support@pallicare.aiims.edu
# Email templates
SES_TEMPLATE_WELCOME=pallicare-welcome
SES_TEMPLATE_ALERT=pallicare-clinical-alert
SES_TEMPLATE_EXPORT_READY=pallicare-export-ready

# ------------------------------------------------------------------------------
# Push Notifications (FCM + APNs)
# ------------------------------------------------------------------------------
# Firebase Cloud Messaging (Android + Web)
FCM_PROJECT_ID=CHANGE_ME_firebase_project_id
FCM_SERVICE_ACCOUNT_PATH=./keys/firebase-service-account.json
# Alternatively, use the JSON directly (for CI/CD environments)
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Apple Push Notification Service (iOS)
APNS_KEY_ID=CHANGE_ME_apns_key_id
APNS_TEAM_ID=CHANGE_ME_apns_team_id
APNS_KEY_PATH=./keys/apns-auth-key.p8
APNS_BUNDLE_ID=edu.aiims.pallicare
APNS_PRODUCTION=false

# WhatsApp Business API (caregiver notifications)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME_phone_number_id
WHATSAPP_ACCESS_TOKEN=CHANGE_ME_whatsapp_token
WHATSAPP_TEMPLATE_ALERT=pallicare_alert_hi
WHATSAPP_TEMPLATE_REMINDER=pallicare_reminder_hi

# ------------------------------------------------------------------------------
# Object Storage (S3 / MinIO)
# ------------------------------------------------------------------------------
# Local: MinIO via Docker Compose
# Production: AWS S3 (ap-south-1)
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_UPLOADS=pallicare-uploads
S3_BUCKET_MEDIA=pallicare-media
S3_BUCKET_BACKUPS=pallicare-backups
S3_BUCKET_EXPORTS=pallicare-exports
# Pre-signed URL expiry (for upload/download links)
S3_PRESIGN_UPLOAD_EXPIRY_SECONDS=600
S3_PRESIGN_DOWNLOAD_EXPIRY_SECONDS=900
# File size limits (bytes)
S3_MAX_VOICE_NOTE_SIZE=10485760
S3_MAX_PHOTO_SIZE=5242880
S3_MAX_EDUCATION_MEDIA_SIZE=52428800
S3_MAX_EXPORT_FILE_SIZE=104857600
# Use path-style URLs (required for MinIO; disable for AWS S3)
S3_FORCE_PATH_STYLE=true

# ------------------------------------------------------------------------------
# CDN (CloudFront)
# ------------------------------------------------------------------------------
CDN_ENABLED=false
CDN_BASE_URL=https://cdn.pallicare.aiims.edu
CDN_DISTRIBUTION_ID=

# ------------------------------------------------------------------------------
# Search (Elasticsearch / OpenSearch)
# ------------------------------------------------------------------------------
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_MEDICATIONS=pallicare-medications
ELASTICSEARCH_INDEX_AUDIT=pallicare-audit
ELASTICSEARCH_INDEX_LOGS=pallicare-app-logs

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
# Global rate limit (requests per IP per window)
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
# Per-endpoint rate limits (override via NestJS decorators)
RATE_LIMIT_AUTH_OTP_MAX=5
RATE_LIMIT_AUTH_OTP_WINDOW_MS=600000
RATE_LIMIT_AUTH_VERIFY_MAX=10
RATE_LIMIT_AUTH_VERIFY_WINDOW_MS=300000
RATE_LIMIT_API_READ_MAX=60
RATE_LIMIT_API_READ_WINDOW_MS=60000
RATE_LIMIT_API_WRITE_MAX=30
RATE_LIMIT_API_WRITE_WINDOW_MS=60000
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000
RATE_LIMIT_EXPORT_MAX=5
RATE_LIMIT_EXPORT_WINDOW_MS=3600000
# Sync endpoint limits
RATE_LIMIT_SYNC_MAX=30
RATE_LIMIT_SYNC_WINDOW_MS=60000

# ------------------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------------------
FEATURE_ABHA_LINKING=true
FEATURE_VOICE_INPUT=true
FEATURE_CAREGIVER_MODE=true
FEATURE_LEGACY_MESSAGES=false
FEATURE_RESEARCH_EXPORT=true
FEATURE_WHATSAPP_NOTIFICATIONS=false
FEATURE_CLINICIAN_DASHBOARD=true
FEATURE_BREATHING_MODULE=true
FEATURE_LEARN_MODULE=true
FEATURE_BODY_MAP_3D=false
FEATURE_FATIGUE_MODE=true
FEATURE_ADAPTIVE_COMPLEXITY=true
FEATURE_OFFLINE_SYNC=true
FEATURE_FHIR_EXPORT=true
FEATURE_MDT_COLLABORATION=false
FEATURE_GOAL_TRACKING=true

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
# Levels: error | warn | info | http | verbose | debug | silly
LOG_FORMAT=pretty
# Formats: json | pretty
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/pallicare.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=14d
# Audit log (always enabled; writes to PostgreSQL + Elasticsearch)
AUDIT_LOG_ENABLED=true
# Request logging (HTTP access log)
REQUEST_LOG_ENABLED=true
REQUEST_LOG_BODY=false

# ------------------------------------------------------------------------------
# Monitoring (Prometheus + Grafana)
# ------------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
# Health check endpoint
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_DB_TIMEOUT_MS=5000
HEALTH_CHECK_REDIS_TIMEOUT_MS=3000

# ------------------------------------------------------------------------------
# Encryption Keys
# ------------------------------------------------------------------------------
# Application-level encryption key (for legacy messages, PHI at rest)
APP_ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key_here
# Used for deterministic encryption of identifiers in research exports
RESEARCH_ANONYMIZATION_SALT=CHANGE_ME_random_salt_here

# ------------------------------------------------------------------------------
# Sync Engine
# ------------------------------------------------------------------------------
SYNC_BATCH_SIZE=50
SYNC_MAX_RETRIES=10
SYNC_RETRY_BASE_DELAY_MS=1000
SYNC_RETRY_MAX_DELAY_MS=300000
SYNC_CONFLICT_STRATEGY=last_write_wins
# Max offline queue size before forced sync
SYNC_MAX_QUEUE_SIZE=500
# Clock drift tolerance for HLC validation
SYNC_MAX_CLOCK_DRIFT_HOURS=24

# ------------------------------------------------------------------------------
# Background Jobs (BullMQ)
# ------------------------------------------------------------------------------
BULL_DEFAULT_ATTEMPTS=3
BULL_DEFAULT_BACKOFF_TYPE=exponential
BULL_DEFAULT_BACKOFF_DELAY=1000
# Job-specific concurrency
BULL_NOTIFICATION_CONCURRENCY=5
BULL_SYNC_CONCURRENCY=3
BULL_ANALYTICS_CONCURRENCY=2
BULL_FHIR_EXPORT_CONCURRENCY=1

# ------------------------------------------------------------------------------
# External Integrations
# ------------------------------------------------------------------------------
# AIIMS e-Hospital EMR integration (optional)
EMR_API_URL=
EMR_API_KEY=
EMR_ENABLED=false

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# Helmet.js security headers
HELMET_ENABLED=true
# Content Security Policy
CSP_REPORT_URI=https://api.pallicare.aiims.edu/csp-report
# IP allowlist for clinician dashboard (comma-separated CIDRs; empty = disabled)
CLINICIAN_IP_ALLOWLIST=
# Request body size limit
BODY_SIZE_LIMIT=10mb
# HSTS max-age in seconds (1 year for production)
HSTS_MAX_AGE=31536000

# ------------------------------------------------------------------------------
# Data Retention (days)
# ------------------------------------------------------------------------------
RETENTION_ACTIVE_PATIENT_DATA=indefinite
RETENTION_ARCHIVED_PATIENT_DATA_DAYS=1825
RETENTION_AUDIT_LOG_HOT_DAYS=365
RETENTION_AUDIT_LOG_COLD_DAYS=2555
RETENTION_VOICE_NOTES_POST_DISCHARGE_DAYS=365
RETENTION_SESSION_DATA_HOURS=24
RETENTION_OTP_MINUTES=5
RETENTION_EXPORT_FILES_DAYS=90
RETENTION_ANONYMOUS_ANALYTICS_DAYS=730
