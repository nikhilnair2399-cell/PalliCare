{
  "name": "pallicare",
  "version": "2.0.0",
  "private": true,
  "description": "PalliCare — Palliative Care, Pain Management & Prehabilitation Platform for AIIMS Bhopal",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "build:dashboard": "npm run build --workspace=apps/dashboard",
    "lint:dashboard": "npm run lint --workspace=apps/dashboard",
    "dev:types": "npm run build --workspace=packages/shared-types",
    "db:migrate": "cd infrastructure && docker compose up -d db",
    "db:seed": "node scripts/seed-db.js",
    "clean": "npm run clean --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aiims-bhopal/pallicare.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
